# =============================================================================
# TrackRock Environment Variables
# Copy this file to .env and fill in values before running
# =============================================================================

# ── Google APIs ───────────────────────────────────────────────────────────────
# Used by backend: Geocoding API, Maps Static API
GOOGLE_MAPS_API_KEY=

# Used by frontend (Vite requires VITE_ prefix for client-side exposure)
VITE_GOOGLE_MAPS_API_KEY=

# Gemini 1.5 Pro — entity resolution, narrative generation, NL query
GOOGLE_GEMINI_API_KEY=

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL + PostGIS (local Docker default below)
DATABASE_URL=postgresql://trackrock:password@localhost:5432/trackrock

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Census API ────────────────────────────────────────────────────────────────
# Free, instant signup: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# ── FRED (Federal Reserve Economic Data) ─────────────────────────────────────
# Free, instant signup: https://fredaccount.stlouisfed.org/apikey
FRED_API_KEY=

# ── HUD Fair Market Rents ─────────────────────────────────────────────────────
# Free, 1-3 day approval: https://www.huduser.gov/portal/dataset/fmr-api.html
HUD_API_TOKEN=

# ── OpenCorporates (optional, boosts entity confidence) ───────────────────────
# Free tier: https://opencorporates.com/api_accounts/new
OPENCORPORATES_API_KEY=

# ── Google Cloud Storage (for CSV/PDF artifact storage) ───────────────────────
GCS_BUCKET_NAME=trackrock-artifacts
GCS_PROJECT_ID=

# ── Seed Data Path ────────────────────────────────────────────────────────────
# Path to processed_owners/ directory from the Python pipeline
# Default: one level up from trackrock/ (inside Projectr_Analytics)
SEED_CSV_DIR=../processed_owners

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
VITE_API_BASE_URL=http://localhost:3001
