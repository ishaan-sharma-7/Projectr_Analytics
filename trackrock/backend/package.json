{
  "name": "@trackrock/backend",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "migrate": "dotenv -e ../.env -- prisma migrate deploy && dotenv -e ../.env -- tsx src/db/applyPostgis.ts",
    "migrate:dev": "dotenv -e ../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../.env -- prisma migrate deploy",
    "generate": "dotenv -e ../.env -- prisma generate",
    "studio": "dotenv -e ../.env -- prisma studio"
  },
  "dependencies": {
    "@google/generative-ai": "^0.15.0",
    "@googlemaps/google-maps-services-js": "^3.4.0",
    "@prisma/client": "^5.14.0",
    "@trackrock/shared": "*",
    "bullmq": "^5.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.3.2",
    "multer": "^1.4.5-lts.1",
    "natural": "^8.0.1",
    "p-limit": "^6.1.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "prisma": "^5.14.0",
    "dotenv-cli": "^7.4.2",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5"
  }
}
